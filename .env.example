# Copy this file to .env.local and fill in your values

# SQLite database (auto-created, no setup needed)
DATABASE_URL="file:./dev.db"

# ── Optional: Live job data from JSearch (RapidAPI) ──────────────────────────
# Sign up free at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier: 200 requests/month
RAPIDAPI_KEY=""
RAPIDAPI_HOST="jsearch.p.rapidapi.com"

# ── Optional: Cron auth token (protects /api/cron/refresh endpoint) ──────────
CRON_SECRET="change-me-to-a-random-string"

# ── App URL (used for Vercel cron) ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
