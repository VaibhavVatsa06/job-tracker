# Copy this file to .env.local and fill in your values

# SQLite database (auto-created, no setup needed)
DATABASE_URL="file:./dev.db"

# ── Optional: Live job data from JSearch (RapidAPI) ──────────────────────────
# Sign up free at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier: 200 requests/month
RAPIDAPI_KEY=""
RAPIDAPI_HOST="jsearch.p.rapidapi.com"

# ── Optional: Adzuna API (free — covers India, UK, Singapore, UAE) ───────────
# Sign up free at https://developer.adzuna.com
# Free tier: 250 requests/day
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""

# ── Optional: Resend (email job alerts) ──────────────────────────────────────
# Sign up free at https://resend.com — 3,000 emails/month free
RESEND_API_KEY=""

# ── Optional: Cron auth token (protects /api/cron/refresh endpoint) ──────────
CRON_SECRET="change-me-to-a-random-string"

# ── App URL (used for Vercel cron) ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
